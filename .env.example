# Runtime mode: "development" (text logs) or "production" (JSON logs).
# In production with WEBHOOK_URL set, TELEGRAM_WEBHOOK_SECRET becomes required.
APP_ENV=development

# Required
BOT_TOKEN=your_bot_token_here

# Your bot's @username (without @). Used for referral deep-links in onboarding messages.
BOT_USERNAME=your_bot_username

# Optional integrations
CRYPTOBOT_TOKEN=
# Public HTTPS URL for Telegram webhook (e.g. https://yourdomain.com). Leave empty to use polling.
WEBHOOK_URL=
# Required in production when WEBHOOK_URL is set. Generate with: openssl rand -hex 32
TELEGRAM_WEBHOOK_SECRET=

# App settings
ADMIN_IDS=
DB_PATH=data/shop.db
LOG_LEVEL=info
LOCALES_DIR=locales
# Telegram Stars per 1 USD. Telegram sells 50 Stars for ~$0.99, so default is 50.
USD_TO_STARS_RATE=50

# Redis is optional. For local binary runs, `localhost:6379` is fine.
# Docker Compose overrides this to `redis:6379` automatically.
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
