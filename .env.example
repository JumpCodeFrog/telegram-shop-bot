# =============================================================
# Telegram Shop Bot — Environment Variables
# =============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Then start the bot:
#   make setup && make run   # local development
#   make docker-up           # Docker
# =============================================================

# ---------------------------
# Required
# ---------------------------

# Telegram Bot token — get it from @BotFather
BOT_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Telegram username of the bot (without @), used for referral deep-links
BOT_USERNAME=my_shop_bot

# Comma-separated Telegram user IDs with admin access
# Example: ADMIN_IDS=123456789,987654321
ADMIN_IDS=123456789

# ---------------------------
# Database
# ---------------------------

# Path to the SQLite database file (created automatically on first run)
DB_PATH=data/shop.db

# ---------------------------
# Redis (FSM state and caching)
# ---------------------------

REDIS_ADDR=localhost:6379
# Leave empty if Redis has no auth
REDIS_PASSWORD=

# ---------------------------
# Payments
# ---------------------------

# Telegram Stars per 1 USD (Telegram sells 50 Stars for ~$0.99)
USD_TO_STARS_RATE=50

# CryptoBot token for USDT/TON payments — get from @CryptoBot → My Apps
# Leave empty to disable crypto payments
CRYPTOBOT_TOKEN=

# ---------------------------
# Webhook (leave empty to use long polling — recommended for development)
# ---------------------------

# Public HTTPS URL where Telegram will POST updates
# Example: https://mybot.example.com/webhook
WEBHOOK_URL=

# Required in production when WEBHOOK_URL is set
# Generate: openssl rand -hex 32
TELEGRAM_WEBHOOK_SECRET=

# ---------------------------
# Outbound Webhooks (optional)
# ---------------------------

# HTTP POST notifications on order events (order.paid, order.delivered)
# Payload: {"event":"order.paid","order_id":1,"user_id":123,"total_usd":9.99,"method":"stars"}
OUTBOUND_WEBHOOK_URL=

# Sent as X-Webhook-Secret header for receiver verification
OUTBOUND_WEBHOOK_SECRET=

# ---------------------------
# Application
# ---------------------------

# Environment: development | production
# In production, webhook secret is enforced and logs are JSON-formatted
APP_ENV=development

# Log level: debug | info | warn | error
LOG_LEVEL=info

# Path to the directory with locale files (ru.json, en.json, ...)
LOCALES_DIR=locales
